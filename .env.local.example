# --- Supabase (client-safe: these are exposed to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Server only: NEVER prefix with NEXT_PUBLIC, never import in a client component ---
# Used by scripts/seed-manager.ts and future server-only routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# --- Seed script only (scripts/seed-manager.ts) ---
SEED_MANAGER_EMAIL=you@example.com
SEED_MANAGER_PASSWORD=change-me-to-a-strong-password
SEED_MANAGER_NAME=Alessandro

# --- Web Push (notifiche) ---
# Genera le chiavi con:  npx web-push generate-vapid-keys
# La PUBLIC key è client-safe (inlined nel bundle); la PRIVATE key è server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
# Segreto condiviso per proteggere /api/cron/push (Vercel invia
# "Authorization: Bearer $CRON_SECRET" alle esecuzioni del cron).
CRON_SECRET=generate-a-long-random-string

# Note (2026): newer Supabase projects issue sb_publishable_... / sb_secret_...
# keys. Legacy anon / service_role keys still work. Keep the variable NAMES
# above and paste whichever key the dashboard gives you.
